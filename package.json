{
  "name": "jumpp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "fetch-data": "node src/scripts/fetchSanityData.js",
    "build": "npm run fetch-data && next build && next export 2>/dev/null",
    "start": "next start -p 3000",
    "start:dev": "next start -p 3001",
    "start:prod": "next start -p 3000",
    "lint": "next lint",
    "deploy": "NODE_ENV=production npm run build && pm2 startOrRestart ecosystem.config.js --only Jumpp",
    "deploy:dev": "npm run build && pm2 startOrRestart ecosystem.config.js --only Jumpp-dev"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.7",
    "@types/axios": "^0.14.0",
    "axios": "^1.7.9",
    "framer-motion": "^11.5.4",
    "html-react-parser": "^5.1.10",
    "intersection-observer": "^0.12.2",
    "lottie-react": "^2.4.0",
    "lottie-web": "^5.12.2",
    "lru-cache": "^11.0.2",
    "next": "^14.1.4",
    "next-sanity": "^9.0.10",
    "rc-slider": "^10.6.2",
    "react": "^18",
    "react-dom": "^18",
    "react-intersection-observer": "^9.10.2",
    "react-redux": "^9.1.2",
    "react-swipeable": "^7.0.1",
    "react-toastify": "^11.0.2",
    "sanity": "^3.39.0",
    "sharp": "^0.33.5",
    "yup": "^1.4.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.7",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.1.4",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
